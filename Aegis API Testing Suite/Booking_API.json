        {
          "name": "Get Booking Details",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "//status code\r",
                  "pm.test(\"Verify Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "//response Body json (firstname=Asmaa)\r",
                  "var jsonData = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Verify first name\", function () {   \r",
                  "    pm.expect(jsonData.firstname).to.eql(\"Asmaa\");\r",
                  "});\r",
                  "\r",
                  "//response Body json (totalprice=1000)\r",
                  "pm.test(\"Verify totalprice\", function () {   \r",
                  "    pm.expect(jsonData.totalprice).to.eql(1000);\r",
                  "});\r",
                  "\r",
                  "//response Body json في حاله ان JSON جوه JSON زي مثال bookingdate.checkin\r",
                  "pm.test(\"Verify checkin date\", function () {   \r",
                  "    pm.expect(jsonData.bookingdates.checkin).to.eql(\"2018-01-01\");\r",
                  "});\r",
                  "\r",
                  "//response Body json في حاله ان JSON جوه JSON زي مثال bookingdate.checkout\r",
                  "pm.test(\"Verify checkout date\", function () {   \r",
                  "    pm.expect(jsonData.bookingdates.checkout).to.eql(\"2019-01-01\");\r",
                  "});\r",
                  "\r",
                  "\r",
                  ""
